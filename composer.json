{
    "name": "pdffiller/laravel-queue-qless",
    "keywords": [
        "qless",
        "queue",
        "jobs",
        "laravel"
    ],
    "homepage": "https://pdffiller.com/",
    "license": "MIT",
    "authors": [
        {
            "name": "Serhii Osadchyi",
            "email": "osadchyi.s@pdffiller.team"
        }
    ],
    "require": {
        "php": "^8.3",
        "ext-json": "*",
        "pdffiller/qless-php": "^3.23"
    },
    "require-dev": {
        "illuminate/contracts": "^11.0 | ^12.0",
        "illuminate/events": "^11.0 | ^12.0",
        "infection/infection": "^0.33.0",
        "orchestra/testbench": "^9.0 | ^10.0",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^12.5",
        "squizlabs/php_codesniffer": "^3.4"
    },
    "autoload": {
        "psr-4": {
            "LaravelQless\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelQless\\Examples\\": "examples/",
            "LaravelQless\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "ocramius/package-versions": true,
            "infection/extension-installer": true
        }
    }
}
